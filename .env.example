# Copy to .env (or set in your shell) to override defaults.

# --- Backend (node) ---
PORT=3001
MCP_BRIDGE_URL=http://127.0.0.1:8001
# AI analysis model for headless `claude -p` (opus = best reasoning, sonnet = faster/cheaper)
ANALYSIS_MODEL=opus
# Path/name of the Claude CLI binary the backend spawns for analysis
CLAUDE_BIN=claude
# Max ms to wait for an AI analysis call before giving up
ANALYSIS_TIMEOUT_MS=240000

# --- MCP bridge (python) ---
# The TradingView MCP server is a local stdio program; override only if it moves.
TV_MCP_COMMAND=uvx
TV_MCP_ARGS=--from,tradingview-mcp-server,tradingview-mcp
TV_MCP_CALL_TIMEOUT=45
